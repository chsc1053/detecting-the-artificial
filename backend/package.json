{
  "name": "backend",
  "version": "1.0.0",
  "description": "REST API for Detecting the Artificial",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "echo \"No automated tests in this repo yet\" && exit 0",
    "migrate:create": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate.js create",
    "migrate:up": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate.js up",
    "migrate:down": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate.js down"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "jstat": "^1.9.6",
    "pg": "^8.20.0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "node-pg-migrate": "^8.0.4"
  }
